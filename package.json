{
  "name": "wenkai-xing-academic-portfolio",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "description": "Wenkai Xing's academic portfolio powered by HugoBlox Academic CV",
  "scripts": {
    "dev": "hugo server --disableFastRender",
    "build": "hugo --minify && pnpm run pagefind",
