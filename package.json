  "dependencies": {
    "@tailwindcss/cli": "4.2.4",
    "@tailwindcss/typography": "0.5.19",
    "pagefind": "1.5.2",
    "preact": "10.29.1",
    "tailwindcss": "4.2.4"
  }
}
